{
  "extensions": {
    "md": { "syntaxAdapter": "./mock-adapter.js" }
  },
  "formats": {
    "doc": {
      "fileNameExtension": "md",
      "handler": "./mock-handler.js",
      "claimResult": false,
      "description": "First doc.",
      "sections": []
    },
    "doc-duplicate": {
      "fileNameExtension": "md",
      "name": "doc",
      "handler": "./mock-handler.js",
      "claimResult": false,
      "description": "Duplicate name — should cause build error.",
      "sections": []
    }
  }
}
