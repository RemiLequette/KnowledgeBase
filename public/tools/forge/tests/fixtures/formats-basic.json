{
  "extensions": {
    "md": { "syntaxAdapter": "./mock-adapter.js" },
    "js": { "syntaxAdapter": "./mock-adapter.js" }
  },
  "formats": {
    "doc": {
      "fileNameExtension": "md",
      "handler": "./mock-handler.js",
      "claimResult": false,
      "description": "A structured Markdown document.",
      "sections": [
        { "name": "why",  "format": "text" },
        { "name": "what", "format": "text" },
        { "name": "how",  "format": "text" }
      ]
    },
    "todo": {
      "fileNameExtension": "md",
      "handler": "./mock-handler.js",
      "claimResult": true,
      "description": "A Markdown backlog.",
      "sections": [
        { "name": "items", "format": "text", "repeat": true }
      ]
    },
    "managed": {
      "fileNameExtension": "js",
      "handler": "./mock-handler.js",
      "claimResult": true,
      "description": "A managed JS file.",
      "sections": [
        { "name": "body", "format": "text" }
      ]
    }
  }
}
