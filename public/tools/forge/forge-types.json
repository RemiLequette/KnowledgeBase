      "description": "a managed JavaScript source file with named blocks",
      "extension": "js",
      "shebang": "// @forge-type: js-managed",
      "blocks": {
        "separators": [
          {
            "type": "regex",
            "pattern": "^// ====\\[ (.+?) \\]====$",
            "nameGroup": 1,
            "repeat": "+"
          }
        ]
      }
    },
    "md-structured": {
      "version": "1.0",
      "handler": "file:///C:/Users/RemiLequette/Development/with-claude/knowledgebase/public/tools/forge/handlers/structured-text.js",
      "description": "a structured Markdown document with named sections",
      "blocks": {
        "separators": [
          {
            "type": "regex",
            "pattern": "^## (.+)$",
            "nameGroup": 1,
            "name": "Changelog",
            "repeat": 1,
            "template": "## {name}",
            "blocks": {
              "separators": [
                {
                  "type": "regex",
                  "pattern": "^### (.+)$",
                  "nameGroup": 1,
                  "repeat": "*",
                  "template": "### {name}"
                }
              ]
            }
          },
